generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  passwordHash  String?                         // ← era String, ahora nullable (usuarios Compita no tienen contraseña KB)
  empresaId     Int?                            // ← NUEVO: id de empresa en Compita
  plan          String?                         // ← NUEVO: plan Compita (ej: "enterprise_platinum")
  isAdmin       Boolean       @default(false)
  createdAt     DateTime      @default(now())
  ownedBoards   Board[]       @relation("BoardOwner")
  ownedBonsais  Bonsai[]      @relation("BonsaiOwner")
  boardMembers  BoardMember[]
  createdCards  Card[]        @relation("CardCreator")
  assignedCards Card[]        @relation("CardAssignee")
  activityLogs  ActivityLog[]
  kbIaUso       KbIaUso[]                       // ← NUEVO: relación con cuota semanal nativa
  @@map("users")
}

// ── NUEVO: cuota semanal de IA para usuarios KB nativos ───────────────────────
model KbIaUso {
  userId    String
  semana    String    // formato 'YYYY-WNN', ej: '2026-W20'
  bonsaisIa Int      @default(0)
  sprintsIa Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([userId, semana])
  @@map("kb_ia_uso")
}

model Bonsai {
  id            String   @id @default(cuid())
  name          String
  description   String?
  ownerId       String
  createdAt     DateTime @default(now())
  owner         User     @relation("BonsaiOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  sprints       Board[]
  generatedByAI Boolean  @default(false)
  aiPrompt      String?
  @@map("bonsais")
}

model Board {
  id           String   @id @default(cuid())
  name         String
  description  String?
  insights     String?
  dependsOnId  String?
  ownerId      String
  bonsaiId     String?
  createdAt    DateTime @default(now())
  owner        User     @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  bonsai       Bonsai?  @relation(fields: [bonsaiId], references: [id])
  columns      Column[]
  members      BoardMember[]
  invitations  BoardInvitation[]
  activityLogs ActivityLog[]
  dependsOn    Board?   @relation("BoardPrecedence", fields: [dependsOnId], references: [id])
  dependents   Board[]  @relation("BoardPrecedence")
  generatedByAI Boolean  @default(false)
  aiPrompt      String?
  @@map("boards")
}

model Column {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  position  Int
  wipLimit  Int?
  color     String?
  createdAt DateTime @default(now())
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]
  @@map("columns")
}

model Card {
  id          String    @id @default(cuid())
  columnId    String
  title       String
  description String?
  assignedTo  String?
  createdBy   String
  position    Int
  priority    String?
  dueDate     DateTime?
  alertDate   DateTime?
  resources   String?
  blockedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  column    Column @relation(fields: [columnId], references: [id], onDelete: Cascade)
  creator   User   @relation("CardCreator",  fields: [createdBy],  references: [id])
  assignee  User?  @relation("CardAssignee", fields: [assignedTo], references: [id])
  blockedBy Card?  @relation("CardPrecedence", fields: [blockedById], references: [id])
  blocks    Card[] @relation("CardPrecedence")
  @@map("cards")
}

model BoardMember {
  boardId   String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([boardId, userId])
  @@map("board_members")
}

model BoardInvitation {
  id        String   @id @default(cuid())
  boardId   String
  email     String
  token     String   @unique @default(cuid())
  status    String   @default("pending")
  createdAt DateTime @default(now())
  expiresAt DateTime
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  @@map("board_invitations")
}

model ActivityLog {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  action    String
  cardTitle String
  fromCol   String?
  toCol     String?
  createdAt DateTime @default(now())
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("activity_logs")
}

model UsageSurvey {
  id             String   @id @default(cuid())
  userId         String?
  email          String
  wantsMore      Boolean
  bonsaisPerWeek Int?
  sprintsPerWeek Int?
  createdAt      DateTime @default(now())
  @@map("usage_surveys")
}
